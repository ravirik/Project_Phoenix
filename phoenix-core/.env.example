# GCP / Vertex AI Credentials
LLM_PROVIDER="gemini"
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1
GEMINI_MODEL=gemini-2.5-flash
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Optional Direct Gemini API Key (if not using GCP Vertex AI)
GEMINI_API_KEY=

# Databases & Message Broker
POSTGRES_USER=phoenix_admin
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=phoenix_telemetry_state
POSTGRES_URL=postgresql://phoenix_admin:your_secure_password@phoenix-postgres-primary:5432/phoenix_telemetry_state

NATS_URL=nats://phoenix-nats-bus:4222
QDRANT_URL=http://phoenix-qdrant-vector:6333
REDIS_URL=redis://phoenix-redis-cache:6379/0

# Telemetry & Observability
LOGFIRE_TOKEN=your_logfire_token_here